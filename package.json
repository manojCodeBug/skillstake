{
  "name": "skillstake",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "contracts/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @skillstake/web",
    "dev:web": "npm run dev --workspace @skillstake/web",
    "dev:api": "npm run dev --workspace @skillstake/api",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.17.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
